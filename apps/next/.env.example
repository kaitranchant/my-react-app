# Copy to apps/next/.env.local (and repo root .env.local for this monorepo) and fill in values.
# Project Settings → API → Project URL (base URL only, no /rest/v1 path)
# and anon/public key

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# ExerciseDB v1 via RapidAPI (server-only — browse & import in Library → Exercises)
# Subscribe: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
EXERCISEDB_RAPIDAPI_KEY=your_rapidapi_key_here
