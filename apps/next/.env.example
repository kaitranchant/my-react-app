# Copy to apps/next/.env.local (and repo root .env.local for this monorepo) and fill in values.
# Project Settings → API → Project URL (base URL only, no /rest/v1 path)
# and anon/public key

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Bundled exercise catalog (JSON + images): yarn workspace next-app sync:exercise-catalog
# Bundled USDA food catalog (JSON): yarn workspace next-app sync:food-catalog

# InBody scan OCR (server-only — coach dashboard photo scan on Progress → InBody)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# E2E tests (optional — yarn workspace next-app seed:e2e && yarn workspace next-app test:e2e)
# Service role key: Supabase Dashboard → Project Settings → API → service_role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Whoop OAuth (server-only — register app at https://developer.whoop.com)
# Redirect URI must match: https://your-domain/api/wearables/whoop/callback
# (or set WHOOP_REDIRECT_URI explicitly for local dev, e.g. http://localhost:3000/api/wearables/whoop/callback)
WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
# WHOOP_REDIRECT_URI=http://localhost:3000/api/wearables/whoop/callback

# Expo mobile app (Apple Health sync) — see apps/expo/.env.example
# EXPO_PUBLIC_API_URL should point at this Next.js app (e.g. http://localhost:3000 or your production URL)

# Email (Resend) — weekly summary cron and future transactional email
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Coaching App <notifications@yourdomain.com>
# APP_URL=https://your-production-domain.com
# CRON_SECRET=generate_a_long_random_string

# Stripe billing (server-only secret key + webhook secret; price IDs from Stripe Dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_GROWTH_MONTHLY=price_...
# STRIPE_PRICE_GROWTH_ANNUAL=price_...
# STRIPE_PRICE_SCALE_MONTHLY=price_...
# STRIPE_PRICE_SCALE_ANNUAL=price_...
# STRIPE_PRICE_FACILITY_MONTHLY=price_...
# STRIPE_PRICE_FACILITY_ANNUAL=price_...

# Web push (browser pop-up notifications)
# Generate keys: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key
# VAPID_PRIVATE_KEY=your_private_key
# VAPID_SUBJECT=mailto:you@yourdomain.com

E2E_COACH_EMAIL=e2e-coach@coaching-app.test
E2E_COACH_PASSWORD=TestPassword123!
E2E_CLIENT_EMAIL=e2e-client@coaching-app.test
E2E_CLIENT_PASSWORD=TestPassword123!
