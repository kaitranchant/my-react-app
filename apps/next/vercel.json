{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && yarn install --immutable",
  "buildCommand": "yarn build",
  "crons": [
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 16 * * 0"
    },
    {
      "path": "/api/cron/client-nudges",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/client-onboarding",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/recurring-series-horizon",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/google-calendar-watch-renewal",
      "schedule": "0 12 * * *"
    }
  ]
}
