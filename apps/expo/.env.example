# Copy to apps/expo/.env for local dev (or set in EAS secrets for cloud builds).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
EXPO_PUBLIC_API_URL=http://localhost:3000

# EAS / TestFlight
# 1. npm install -g eas-cli && eas login
# 2. cd apps/expo && eas init
# 3. Set EXPO_PUBLIC_* in eas.json or EAS secrets (Expo dashboard → Secrets)
# 4. eas build --profile preview --platform ios
# 5. eas submit --platform ios --profile production
